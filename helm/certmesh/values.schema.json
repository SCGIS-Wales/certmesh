{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "image": {
      "type": "object",
      "properties": {
        "repository": { "type": "string", "pattern": "^[a-z0-9._/-]+$" },
        "tag": { "type": "string", "maxLength": 128 },
        "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
      }
    },
    "nameOverride": { "type": "string", "maxLength": 63, "pattern": "^[a-z0-9-]*$" },
    "fullnameOverride": { "type": "string", "maxLength": 63, "pattern": "^[a-z0-9-]*$" },
    "namespace": { "type": "string", "maxLength": 63, "pattern": "^[a-z0-9-]*$" },
    "companyPrefix": { "type": "string", "maxLength": 32, "pattern": "^[a-z0-9-]*$" },
    "resourcePrefix": { "type": "string", "maxLength": 32, "pattern": "^[a-z0-9-]*$" },
    "replicaCount": { "type": "integer", "minimum": 1, "maximum": 100 },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string", "maxLength": 253 }
      }
    },
    "vault": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "url": { "type": "string", "maxLength": 512 },
        "authMethod": { "type": "string", "enum": ["approle", "kubernetes", "ldap", "aws_iam"] },
        "kvVersion": { "type": "integer", "enum": [1, 2] },
        "tls": {
          "type": "object",
          "properties": {
            "verify": { "type": "boolean" }
          }
        }
      }
    },
    "oauth2": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "issuerUrl": { "type": "string", "maxLength": 512 },
        "audience": { "type": "string", "maxLength": 256 },
        "providerHint": { "type": "string", "enum": ["generic", "auth0", "keycloak", "okta", "adfs", "entra_id"] }
      }
    },
    "apiKey": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "defaultTtlSeconds": { "type": "integer", "minimum": 60, "maximum": 28800 },
        "maxTtlSeconds": { "type": "integer", "minimum": 60, "maximum": 86400 },
        "maxActiveKeys": { "type": "integer", "minimum": 1, "maximum": 1000000 },
        "maxKeysPerSubject": { "type": "integer", "minimum": 1, "maximum": 1000 }
      }
    },
    "rateLimit": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "defaultLimit": { "type": "string", "pattern": "^[0-9]+/(second|minute|hour|day)$" },
        "burstLimit": { "type": "string", "pattern": "^[0-9]+/(second|minute|hour|day)$" }
      }
    },
    "api": {
      "type": "object",
      "properties": {
        "workers": { "type": ["string", "integer"] },
        "timeout": { "type": "integer", "minimum": 1, "maximum": 3600 },
        "logLevel": { "type": "string", "enum": ["debug", "info", "warning", "error", "critical"] }
      }
    },
    "service": {
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["ClusterIP", "NodePort", "LoadBalancer"] },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 }
      }
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "className": { "type": "string", "maxLength": 63 }
      }
    },
    "networkPolicy": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "ingressCIDRs": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[0-9]{1,3}(\\.[0-9]{1,3}){3}/[0-9]{1,2}$" }
        },
        "egressCIDRs": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[0-9]{1,3}(\\.[0-9]{1,3}){3}/[0-9]{1,2}$" }
        },
        "ingressPorts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
              "protocol": { "type": "string", "enum": ["TCP", "UDP"] }
            },
            "required": ["port", "protocol"]
          }
        }
      }
    },
    "resources": {
      "type": "object",
      "properties": {
        "requests": { "type": "object" },
        "limits": { "type": "object" }
      }
    },
    "autoscaling": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "minReplicas": { "type": "integer", "minimum": 1, "maximum": 100 },
        "maxReplicas": { "type": "integer", "minimum": 1, "maximum": 1000 },
        "targetCPUUtilization": { "type": "integer", "minimum": 1, "maximum": 100 },
        "targetMemoryUtilization": { "type": "integer", "minimum": 1, "maximum": 100 }
      }
    },
    "securityContext": {
      "type": "object",
      "properties": {
        "runAsNonRoot": { "type": "boolean" },
        "runAsUser": { "type": "integer", "minimum": 0 },
        "fsGroup": { "type": "integer", "minimum": 0 }
      }
    },
    "containerSecurityContext": {
      "type": "object",
      "properties": {
        "allowPrivilegeEscalation": { "type": "boolean" },
        "readOnlyRootFilesystem": { "type": "boolean" }
      }
    },
    "digicert": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "apiKeySource": { "type": "string", "enum": ["vault", "env"] },
        "baseUrl": { "type": "string", "maxLength": 512 }
      }
    },
    "venafi": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "authMethod": { "type": "string", "enum": ["oauth", "ldap"] },
        "tlsVerify": { "type": "boolean" }
      }
    },
    "acm": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "region": { "type": "string", "pattern": "^[a-z]{2}-[a-z]+-[0-9]+$" }
      }
    },
    "letsencrypt": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "challengeType": { "type": "string", "enum": ["dns-01", "http-01"] },
        "agreeTos": { "type": "boolean" }
      }
    },
    "certRenewal": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "schedule": { "type": "string", "maxLength": 64 },
        "beforeExpiry": { "type": "integer", "minimum": 1 },
        "unit": { "type": "string", "enum": ["hour", "day", "week", "month", "year"] }
      }
    },
    "persistence": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "size": { "type": "string", "pattern": "^[0-9]+(Mi|Gi|Ti)$" }
      }
    }
  }
}
